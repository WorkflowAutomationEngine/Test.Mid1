<Project>

  <PropertyGroup>

    <!-- Package -->
    <PackageId>Test.Mid1</PackageId>

    <!-- Base Version -->
    <VersionPrefix>1.0.0</VersionPrefix>

    <!-- Metadata -->
    <Authors>WorkflowAutomationEngine</Authors>
    <Company>WorkflowAutomationEngine</Company>

    <Description>
      Sample Mid1 NuGet package for WorkflowAutomationEngine PoC.
    </Description>

    <PackageTags>
      workflow;automation;sample
    </PackageTags>

    <RepositoryUrl>
      https://github.com/WorkflowAutomationEngine/Test.Mid1
    </RepositoryUrl>

    <RepositoryType>git</RepositoryType>

    <!-- Packaging -->
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>

  </PropertyGroup>

</Project>